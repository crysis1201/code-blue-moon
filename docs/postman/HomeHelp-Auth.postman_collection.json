{
  "info": {
    "name": "HomeHelp — Auth Module",
    "description": "Authentication endpoints for HomeHelp API.\n\nDev mode: Use OTP `123456` for any phone number.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000/v1" },
    { "key": "phone", "value": "+919876543210" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/../health",
          "host": ["{{base_url}}", "..", "health"]
        }
      }
    },
    {
      "name": "Send OTP",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/auth/otp/send",
          "host": ["{{base_url}}"],
          "path": ["auth", "otp", "send"]
        },
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{phone}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('OTP sent successfully', function () {",
              "    pm.response.to.have.status(200);",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Verify OTP (Household)",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/auth/otp/verify",
          "host": ["{{base_url}}"],
          "path": ["auth", "otp", "verify"]
        },
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"otp\": \"123456\",\n  \"role\": \"household\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('OTP verified and tokens received', function () {",
              "    pm.response.to.have.status(200);",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "    pm.expect(json.data.accessToken).to.be.a('string');",
              "    pm.expect(json.data.refreshToken).to.be.a('string');",
              "",
              "    pm.collectionVariables.set('access_token', json.data.accessToken);",
              "    pm.collectionVariables.set('refresh_token', json.data.refreshToken);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Verify OTP (Helper)",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/auth/otp/verify",
          "host": ["{{base_url}}"],
          "path": ["auth", "otp", "verify"]
        },
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"+919876543211\",\n  \"otp\": \"123456\",\n  \"role\": \"helper\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Helper OTP verified', function () {",
              "    pm.response.to.have.status(200);",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "    pm.expect(json.data.user.role).to.eql('helper');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/auth/refresh",
          "host": ["{{base_url}}"],
          "path": ["auth", "refresh"]
        },
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Tokens refreshed', function () {",
              "    pm.response.to.have.status(200);",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "",
              "    pm.collectionVariables.set('access_token', json.data.accessToken);",
              "    pm.collectionVariables.set('refresh_token', json.data.refreshToken);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/auth/logout",
          "host": ["{{base_url}}"],
          "path": ["auth", "logout"]
        },
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Logged out', function () {",
              "    pm.response.to.have.status(200);",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Logout All Devices",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/auth/logout",
          "host": ["{{base_url}}"],
          "path": ["auth", "logout"]
        },
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Logged out from all devices', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
