# Database (Railway Postgres)
DATABASE_URL=postgresql://user:pass@host:5432/homehelp

# Redis (Railway Redis)
REDIS_URL=redis://default:pass@host:6379

# JWT RS256 Keys (base64-encoded PEM content)
# Generate keys: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Encode: cat private.pem | base64 | tr -d '\n'
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=

# MSG91 (OTP provider)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=HomeHelp

# Cashfree
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=SANDBOX
APP_BASE_URL=http://localhost:3000

# App
PORT=3000
NODE_ENV=development
