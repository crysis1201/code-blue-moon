{
  "info": {
    "name": "HomeHelp — Search & Discovery",
    "description": "Search helpers, view profiles, check availability, get price estimates.\n\nRequires a household token. Run Auth collection first.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000/v1" },
    { "key": "household_token", "value": "" },
    { "key": "helper_profile_id", "value": "" }
  ],
  "item": [
    {
      "name": "Setup — Login as Household",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/auth/otp/verify", "host": ["{{base_url}}"], "path": ["auth", "otp", "verify"] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+919876543210\",\n  \"otp\": \"123456\",\n  \"role\": \"household\"\n}" }
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "var json = pm.response.json();",
        "if (json.success) { pm.collectionVariables.set('household_token', json.data.accessToken); }"
      ]}}]
    },
    {
      "name": "Search Helpers (Cook, Koramangala)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/search/helpers?service_type=cook&latitude=12.9352&longitude=77.6245&radius_km=5&sort_by=relevance&page=1&limit=20",
          "host": ["{{base_url}}"],
          "path": ["search", "helpers"],
          "query": [
            { "key": "service_type", "value": "cook" },
            { "key": "latitude", "value": "12.9352" },
            { "key": "longitude", "value": "77.6245" },
            { "key": "radius_km", "value": "5" },
            { "key": "sort_by", "value": "relevance" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "20" }
          ]
        },
        "header": [{ "key": "Authorization", "value": "Bearer {{household_token}}" }]
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Search returned results', function () {",
        "    pm.response.to.have.status(200);",
        "    var json = pm.response.json();",
        "    pm.expect(json.success).to.eql(true);",
        "    if (json.data.helpers.length > 0) {",
        "        pm.collectionVariables.set('helper_profile_id', json.data.helpers[0].id);",
        "    }",
        "});"
      ]}}]
    },
    {
      "name": "Search Helpers (with budget & cuisine filter)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/search/helpers?service_type=cook&latitude=12.9352&longitude=77.6245&radius_km=10&cuisine=south_indian&budget_min=5000&budget_max=15000&sort_by=price_low",
          "host": ["{{base_url}}"],
          "path": ["search", "helpers"],
          "query": [
            { "key": "service_type", "value": "cook" },
            { "key": "latitude", "value": "12.9352" },
            { "key": "longitude", "value": "77.6245" },
            { "key": "radius_km", "value": "10" },
            { "key": "cuisine", "value": "south_indian" },
            { "key": "budget_min", "value": "5000" },
            { "key": "budget_max", "value": "15000" },
            { "key": "sort_by", "value": "price_low" }
          ]
        },
        "header": [{ "key": "Authorization", "value": "Bearer {{household_token}}" }]
      }
    },
    {
      "name": "Search Helpers (sort by distance)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/search/helpers?service_type=cook&latitude=12.9352&longitude=77.6245&radius_km=10&sort_by=distance",
          "host": ["{{base_url}}"],
          "path": ["search", "helpers"],
          "query": [
            { "key": "service_type", "value": "cook" },
            { "key": "latitude", "value": "12.9352" },
            { "key": "longitude", "value": "77.6245" },
            { "key": "radius_km", "value": "10" },
            { "key": "sort_by", "value": "distance" }
          ]
        },
        "header": [{ "key": "Authorization", "value": "Bearer {{household_token}}" }]
      }
    },
    {
      "name": "Get Helper Full Profile",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/search/helpers/{{helper_profile_id}}",
          "host": ["{{base_url}}"],
          "path": ["search", "helpers", "{{helper_profile_id}}"]
        },
        "header": [{ "key": "Authorization", "value": "Bearer {{household_token}}" }]
      }
    },
    {
      "name": "Get Helper Availability",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/search/helpers/{{helper_profile_id}}/availability",
          "host": ["{{base_url}}"],
          "path": ["search", "helpers", "{{helper_profile_id}}", "availability"]
        },
        "header": [{ "key": "Authorization", "value": "Bearer {{household_token}}" }]
      }
    },
    {
      "name": "Get Price Estimate",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/search/price-estimate?helper_id={{helper_profile_id}}&meals=2&visits_per_day=1&family_size=4&include_weekends=false&non_veg=true&grocery_shopping=false",
          "host": ["{{base_url}}"],
          "path": ["search", "price-estimate"],
          "query": [
            { "key": "helper_id", "value": "{{helper_profile_id}}" },
            { "key": "meals", "value": "2" },
            { "key": "visits_per_day", "value": "1" },
            { "key": "family_size", "value": "4" },
            { "key": "include_weekends", "value": "false" },
            { "key": "non_veg", "value": "true" },
            { "key": "grocery_shopping", "value": "false" }
          ]
        },
        "header": [{ "key": "Authorization", "value": "Bearer {{household_token}}" }]
      }
    }
  ]
}
