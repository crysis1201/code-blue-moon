{
  "info": {
    "name": "HomeHelp — Admin API",
    "description": "Admin dashboard, user management, verifications, bookings, payments overview.\n\nRequires admin role. Create an admin user first.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000/v1" },
    { "key": "admin_token", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "helper_id", "value": "" }
  ],
  "item": [
    {
      "name": "Setup — Login as Admin",
      "description": "First create an admin user by manually setting role='admin' in the DB, then login.",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/auth/otp/verify", "host": ["{{base_url}}"], "path": ["auth", "otp", "verify"] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+919876543299\",\n  \"otp\": \"123456\",\n  \"role\": \"household\"\n}" }
      },
      "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json(); if (json.success) pm.collectionVariables.set('admin_token', json.data.accessToken);"] }}]
    },
    {
      "name": "Dashboard",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/admin/dashboard", "host": ["{{base_url}}"], "path": ["admin", "dashboard"] },
        "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
      }
    },
    {
      "name": "List Users",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/admin/users?page=1&limit=20", "host": ["{{base_url}}"], "path": ["admin", "users"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}] },
        "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "var json = pm.response.json();",
        "if (json.success && json.data.users.length > 0) pm.collectionVariables.set('user_id', json.data.users[0].id);"
      ]}}]
    },
    {
      "name": "Get User Detail",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/admin/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["admin", "users", "{{user_id}}"] },
        "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
      }
    },
    {
      "name": "Suspend User",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/admin/users/{{user_id}}/suspend", "host": ["{{base_url}}"], "path": ["admin", "users", "{{user_id}}", "suspend"] },
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{admin_token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Repeated no-shows\"\n}" }
      }
    },
    {
      "name": "Verification Queue",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/admin/verifications?page=1&limit=20", "host": ["{{base_url}}"], "path": ["admin", "verifications"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}] },
        "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
      }
    },
    {
      "name": "Approve Verification",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/admin/verifications/{{helper_id}}/approve", "host": ["{{base_url}}"], "path": ["admin", "verifications", "{{helper_id}}", "approve"] },
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{admin_token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"type\": \"aadhaar\"\n}" }
      }
    },
    {
      "name": "List Bookings",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/admin/bookings?page=1&limit=20", "host": ["{{base_url}}"], "path": ["admin", "bookings"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}] },
        "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
      }
    },
    {
      "name": "Payment Overview",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/admin/payments/overview?month=2026-04", "host": ["{{base_url}}"], "path": ["admin", "payments", "overview"], "query": [{"key":"month","value":"2026-04"}] },
        "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
      }
    },
    {
      "name": "Failed Payouts",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/admin/payments/failed-payouts", "host": ["{{base_url}}"], "path": ["admin", "payments", "failed-payouts"] },
        "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
      }
    }
  ]
}
